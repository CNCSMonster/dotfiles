% mdbook

; mdbook 文档工具相关

# 初始化 mdbook 项目
mdbook init <dir>
$ dir: printf '\nmy-book'

# 构建 mdbook
mdbook build <dir>
$ dir: printf '\n.'

# 实时预览 mdbook（自动重载）
mdbook serve <dir> --open
$ dir: printf '\n.'

# 清理构建产物
mdbook clean <dir>
$ dir: printf '\n.'

# 为项目安装/更新 mermaid 支持
mdbook-mermaid install <dir>
$ dir: printf '\n.'

% mdbook-mermaid

; mdbook-mermaid 图表预处理器

# 为项目安装/更新 mermaid 支持
# 会自动修改 book.toml 并复制 mermaid.min.js 和 mermaid-init.js
mdbook-mermaid install <book>
$ book: printf '\n.'
