[user]
    name = cncsmonster
    email = cncsmonster@163.com
[init]
    defaultBranch = main
[core]
    # pager = delta
    editor = code
    # 全局忽略文件（不纳入版本控制的本地文件）
    excludesFile = ~/.config/git/.gitignore_global
[interactive]
    diffFilter = delta --color-only
[delta]
    side-by-side = true
    line-numbers-left-format = ""
    line-numbers-right-format = "│ "
    syntax-theme = Nord
[log]
    date = iso-strict-local
[trim]
    bases = develop,master,main
